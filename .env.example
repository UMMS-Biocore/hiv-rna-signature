# Copy to .env (which is gitignored) and fill in real values.
# Never commit .env.

# Zenodo personal access token.
# Create at: https://zenodo.org/account/settings/applications/tokens/new/
# Scopes: deposit:write, deposit:actions
ZENODO_TOKEN=replace_me

# Numeric ID of the published Zenodo record used by scripts/download_data.sh.
ZENODO_RECORD_ID=19699922
